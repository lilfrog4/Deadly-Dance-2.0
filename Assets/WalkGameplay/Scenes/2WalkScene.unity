--- !u!114 &121473917
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 121473915}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: aa8c7727c414a1f4d9976550d7738ef4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSystem
  panel: {fileID: 938035782}
  text: {fileID: 604897649}
  dialogues:
  - name: Trigger1
    phrases:
    - "\u0413\u043E\u0440\u044B..."
    - ...
    - "\u0412\u0430\u0448\u0430 \u0441\u0432\u043E\u0431\u043E\u0434\u0430 \u0437\u0430\u043A\u0430\u043D\u0447\u0438\u0432\u0430\u0435\u0442\u0441\u044F
      \u0437\u0434\u0435\u0441\u044C."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: Trigger1 (1)
    phrases:
    - "\u0413\u043E\u0440\u044B..."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: b1
    phrases:
    - "\u041F\u0440\u0438\u0432\u0435\u0442, \u041A\u0440\u0438\u0441!\n"
    - "\u041E\u0442\u043A\u0443\u0434\u0430 \u0442\u044B \u0437\u043D\u0430\u0435\u0448\u044C..."
    - "\u0410 \u0432 \u043F\u0440\u043E\u0447\u0435\u043C, \u043D\u0435 \u0432\u0430\u0436\u043D\u043E."
    - "\u041A\u0442\u043E \u0442\u044B?"
    - "\u042F - \u041C\u0430\u044D\u0441\u0442\u0440\u043E, \u0412\u0435\u043B\u0438\u043A\u0438\u0439
      \u0438 \u0423\u0436\u0430\u0441\u043D\u044B\u0439! "
    - "\u0425\u043E\u0442\u044F, \u0432 \u043F\u043E\u0441\u043B\u0435\u0434\u043D\u0435\u0435
      \u0432\u0440\u0435\u043C\u044F \u043D\u0430\u0432\u0435\u0440\u043D\u043E\u0435
      \u043D\u0435 \u043E\u0447\u0435\u043D\u044C \u0432\u0435\u043B\u0438\u043A\u0438\u0439."
    - "\u041D\u0430 \u043C\u043E\u0438\u0445 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u0445
      \u0432\u0441\u0435 \u043C\u0435\u043D\u044C\u0448\u0435 \u0438 \u043C\u0435\u043D\u044C\u0448\u0435
      \u0437\u0440\u0438\u0442\u0435\u043B\u0435\u0439!"
    - "\u0418 \u043A\u0430\u0436\u0435\u0442\u0441\u044F \u044F \u043F\u043E\u043D\u044F\u043B,
      \u0432 \u0447\u0451\u043C \u043F\u0440\u043E\u0431\u043B\u0435\u043C\u0430.\n"
    - "\u0414\u043B\u044F \u043C\u043E\u0438\u0445 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0439
      \u043C\u043D\u0435 \u043D\u0443\u0436\u043D\u044B \u043D\u043E\u0432\u044B\u0435,
      \u0441\u0432\u0435\u0436\u0438\u0435 \u0430\u0440\u0442\u0438\u0441\u0442\u044B."
    - "\u0422\u044B \u0431\u044B \u043C\u043E\u0433 \u0441\u043E\u0439\u0442\u0438
      \u0437\u0430 \u0442\u0430\u043A\u043E\u0433\u043E."
    - "\u0422\u0430\u043A \u0447\u0442\u043E, \u0442\u0435\u0431\u0435 \u043D\u0443\u0436\u043D\u0430
      \u0440\u0430\u0431\u043E\u0442\u0430? \u042F \u0436\u0435 \u0432\u0438\u0436\u0443,
      \u0447\u0442\u043E \u0442\u044B \u0445\u043E\u0447\u0435\u0448\u044C."
    - "\u0423\u0447\u0430\u0441\u0442\u0432\u043E\u0432\u0430\u0442\u044C \u0432
      \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u044F\u0445?
      \u0410 \u0447\u0442\u043E, \u0437\u0432\u0443\u0447\u0438\u0442 \u043D\u0435\u043F\u043B\u043E\u0445\u043E.\u042F
      \u0441\u043E\u0433\u043B\u0430\u0441\u0435\u043D."
    - "\u041E\u0442\u043B\u0438\u0447\u043D\u043E!"
    - "\u041D\u0430\u0447\u043D\u0435\u043C \u043D\u0435\u043C\u0435\u0434\u043B\u0435\u043D\u043D\u043E."
    - "\u041F\u0440\u0430\u0432\u0434\u0430, \u0435\u0441\u0442\u044C \u043E\u0434\u0438\u043D
      \u043D\u044E\u0430\u043D\u0441. \u042D\u0442\u043E\u0442 \u043D\u043E\u043C\u0435\u0440
      \u0431\u0443\u0434\u0435\u0442 \u0434\u043B\u044F \u0442\u0435\u0431\u044F..."
    - "\u0421\u041C\u0415\u0420\u0422\u0415\u041B\u042C\u041D\u042B\u041C"
    - "\u0425\u043C..."
    - "\u0422\u044B \u0443\u0436\u0435 \u0441\u043E\u0433\u043B\u0430\u0441\u0438\u043B\u0441\u044F.
      \u041D\u0430\u0447\u0438\u043D\u0430\u0435\u043C!"
    phraseColors:
    - {r: 0.8894532, g: 0.19811308, b: 1, a: 1}
    - {r: 1, g: 0.5060443, b: 0, a: 1}

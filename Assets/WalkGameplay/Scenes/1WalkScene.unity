--- !u!114 &384048863
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 384048861}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: aa8c7727c414a1f4d9976550d7738ef4, type: 3}
  m_Name: 
  m_EditorClassIdentifier: Assembly-CSharp::DialogueSystem
  panel: {fileID: 0}
  text: {fileID: 0}
  dialogues:
  - name: 
    phrases:
    - "\u0425\u043C, \u043A\u0430\u0436\u0435\u0442\u0441\u044F, \u044D\u0442\u043E
      \u043A\u0440\u0430\u0439."
    - "\u041D\u043E \u043A\u0442\u043E \u0441\u043A\u0430\u0437\u0430\u043B, \u0447\u0442\u043E
      \u044D\u0442\u043E \u043A\u043E\u043D\u0435\u0446?"
    - "\u041D\u0438\u0447\u0442\u043E \u043D\u0435 \u043C\u0435\u0448\u0430\u0435\u0442
      \u0432\u0430\u043C \u0438\u0434\u0442\u0438 \u0434\u0430\u043B\u044C\u0448\u0435."
    - "\u0414\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u0434\u0430\u043B\u044C\u0448\u0435
      \u043D\u0438\u0447\u0435\u0433\u043E \u043D\u0435\u0442."
    - "\u041F\u0440\u043E\u0441\u0442\u043E\u0440 \u043E\u0442\u043A\u0440\u044B\u0442!
      \u041D\u043E \u043B\u0443\u0447\u0448\u0435 \u0432\u0430\u043C \u0432\u0441\u0451-\u0442\u0430\u043A\u0438
      \u0432\u0435\u0440\u043D\u0443\u0442\u0441\u044F."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: 
    phrases:
    - "\u041A\u043E\u0433\u0434\u0430 \u043D\u0438\u0431\u0443\u0434\u044C \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u044B
      \u0431\u0443\u0434\u0443\u0442 \u0440\u0430\u0431\u043E\u0442\u0430\u0442\u044C."
    - "\u0412\u0441\u0435\u043C\u0443 \u0441\u0432\u043E\u0451 \u0432\u0440\u0435\u043C\u044F."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: 
    phrases:
    - "\u0412 \u043F\u043E\u0447\u0442\u043E\u0432\u043E\u043C \u044F\u0449\u0438\u043A\u0435
      \u0432\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0435 \u0446\u0432\u0435\u0442\u0430\u0441\u0442\u0443\u044E
      \u043A\u0430\u0440\u0442\u0438\u043D\u043A\u0443."
    - "\u041A\u0430\u0436\u0435\u0442\u0441\u044F, \u044D\u0442\u043E \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435
      \u043D\u0430 \u0441\u043E\u0431\u0435\u0441\u0435\u0434\u043E\u0432\u0430\u043D\u0438\u0435
      \u0432 \u0430\u0440\u0442\u0438\u0441\u0442\u044B."
    - "\u0412\u044B \u0445\u043E\u0442\u0438\u0442\u0435 \u0432\u0437\u044F\u0442\u044C
      \u044D\u0442\u043E"
    - "\u042D\u0442\u043E \u043D\u0435 \u0432\u043E\u043F\u0440\u043E\u0441. \u041F\u043E\u043A\u0430
      \u0447\u0442\u043E."
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 enter, \u0447\u0442\u043E\u0431\u044B
      \u0437\u0430\u0432\u043B\u0430\u0434\u0435\u0442\u044C \u044D\u0442\u0438\u043C."
    - "\u0412\u044B \u0432\u0437\u044F\u043B\u0438 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435.
      \u0412 \u0431\u0443\u0434\u0443\u0449\u0435\u043C \u0435\u0433\u043E \u043C\u043E\u0436\u043D\u043E
      \u0431\u0443\u0434\u0435\u0442 \u043D\u0435 \u0431\u0440\u0430\u0442\u044C."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: 
    phrases:
    - "\u0421\u0442\u0440\u0430\u043D\u043D\u0430\u044F \u0434\u0432\u0435\u0440\u044C,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0437\u0434\u0435\u0441\u044C \u0440\u0430\u043D\u044C\u0448\u0435
      \u043D\u0435 \u0431\u044B\u043B\u043E."
    - "\u0412\u043E\u0439\u0442\u0438 \u0432 \u0434\u0432\u0435\u0440\u044C, \u043A\u043E\u0442\u043E\u0440\u043E\u0439
      \u0440\u0430\u043D\u044C\u0448\u0435 \u0437\u0434\u0435\u0441\u044C \u043D\u0435
      \u0431\u044B\u043B\u043E?"
    - "\u041A\u043E\u043D\u0435\u0447\u043D\u043E \u0436\u0435 \u0434\u0430, \u043A\u0430\u043A
      \u0438\u043D\u0430\u0447\u0435?!"
    - "\u041A\u043E\u043D\u0435\u0447\u043D\u043E \u0436\u0435 \u0434\u0430, \u043A\u0430\u043A
      \u0438\u043D\u0430\u0447\u0435?!"
    - "\u0411\u0443\u043A\u0432\u0430\u043B\u044C\u043D\u043E."
    - ...
    - "\u041F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0435\u043C\u0441\u044F!"
    phraseColors: []
    uses: 1
    nextScene: 

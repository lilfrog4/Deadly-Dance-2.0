    - "\u0414\u0430\u0436\u0435 \u0435\u0441\u043B\u0438 \u0442\u0430\u043C \u043D\u0438\u0447\u0435\u0433\u043E
      \u043D\u0435\u0442.\r\n"
    - "\u041F\u0440\u043E\u0441\u0442\u043E\u0440 \u043E\u0442\u043A\u0440\u044B\u0442!
      \u041D\u043E \u043B\u0443\u0447\u0448\u0435 \u0432\u0430\u043C \u0432\u0441\u0451-\u0442\u0430\u043A\u0438
      \u0432\u0435\u0440\u043D\u0443\u0442\u0441\u044F."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: Trigger3
    phrases:
    - "\u0417\u0435\u043C\u043B\u0438 \u043D\u0435 \u0441\u0443\u0449\u0435\u0441\u0442\u0432\u0443\u0435\u0442."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: "\u043A\u043D\u043E\u043F\u043A_1"
    phrases:
    - "\u0412 \u043F\u043E\u0447\u0442\u043E\u0432\u043E\u043C \u044F\u0449\u0438\u043A\u0435
      \u0432\u044B \u043D\u0430\u0445\u043E\u0434\u0438\u0442\u0435 \u0446\u0432\u0435\u0442\u0430\u0441\u0442\u043E\u0435
      \u043E\u0431\u044A\u044F\u0432\u043B\u0435\u043D\u0438\u0435."
    - "\"\u041D\u0430 \u0446\u0438\u0440\u043A\u043E\u0432\u043E\u0435 \u043F\u0440\u0435\u0434\u0441\u0442\u0430\u0432\u043B\u0435\u043D\u0438\u0435
      \u0442\u0440\u0435\u0431\u0443\u044E\u0442\u0441\u044F \u0430\u0440\u0442\u0438\u0441\u0442\u044B,
      \u0441\u043F\u0440\u0430\u0448\u0438\u0432\u0430\u0442\u044C \u041C\u0430\u044D\u0441\u0442\u0440\u043E\"."
    - "\u0412\u044B \u0445\u043E\u0442\u0438\u0442\u0435 \u0432\u0437\u044F\u0442\u044C
      \u044D\u0442\u043E."
    - "\u041D\u0430\u0436\u043C\u0438\u0442\u0435 enter, \u0447\u0442\u043E\u0431\u044B
      \u0437\u0430\u0432\u043B\u0430\u0434\u0435\u0442\u044C.\r\n"
    - "\u0412\u044B \u0432\u0437\u044F\u043B\u0438 \u043F\u0440\u0438\u0433\u043B\u0430\u0448\u0435\u043D\u0438\u0435."
    phraseColors: []
    uses: 1
    nextScene: 
  - name: "\u043A\u043D\u043E\u043F\u043A_1 (1)"
    phrases:
    - "\u0421\u0442\u0440\u0430\u043D\u043D\u0430\u044F \u0434\u0432\u0435\u0440\u044C,
      \u043A\u043E\u0442\u043E\u0440\u043E\u0439 \u0440\u0430\u043D\u044C\u0448\u0435
      \u0437\u0434\u0435\u0441\u044C \u043D\u0435 \u0431\u044B\u043B\u043E."
    - "\u0412\u043E\u0439\u0442\u0438 \u0432 \u0434\u0432\u0435\u0440\u044C, \u043A\u043E\u0442\u043E\u0440\u043E\u0439
      \u0440\u0430\u043D\u044C\u0448\u0435 \u0437\u0434\u0435\u0441\u044C \u043D\u0435
      \u0431\u044B\u043B\u043E?"
    - "\u0421\u0430\u043C\u043E \u0441\u043E\u0431\u043E\u0439."
    - ...
    - "\u041F\u0435\u0440\u0435\u043C\u0435\u0449\u0430\u0435\u043C\u0441\u044F!"
    phraseColors: []
    uses: 999
    nextScene: 2WalkScene
  - name: "\u043A\u043D\u043E\u043F\u043A2"
    phrases:
    - "\u041F\u043E \u043A\u0430\u043A\u0438\u043C-\u0442\u043E \u043D\u0435\u043E\u0431\u044A\u044F\u0441\u043D\u0438\u043C\u044B\u043C
      \u043F\u0440\u0438\u0447\u0438\u043D\u0430\u043C, \u0432\u044B \u043D\u0435
      \u043C\u043E\u0436\u0435\u0442\u0435 \u0437\u0430\u0431\u0440\u0430\u0442\u044C\u0441\u044F
      \u043F\u043E \u044D\u0442\u043E\u0439 \u043B\u0435\u0441\u0442\u043D\u0438\u0446\u0435."
    - "\u0412\u043F\u0440\u043E\u0447\u0435\u043C, \u044D\u0442\u043E \u0432\u0430\u043C
      \u0438 \u043D\u0435 \u043D\u0443\u0436\u043D\u043E."
    phraseColors: []
    uses: 1
    nextScene: 
